--c#

#include <ESP8266WiFi.h>

const char* ssid = "SEU_WIFI";
const char* senha = "SUA_SENHA";

void setup() {
  Serial.begin(115200);

  WiFi.begin(ssid, senha);

  Serial.print("Conectando");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nConectado!");
  Serial.print("IP: ");
  Serial.println(WiFi.localIP());
}

void loop() {}
